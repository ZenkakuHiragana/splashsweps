# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Mac crap
.DS_Store

# Executables and other
*.dll
*.exe
*.ico
*.zip
*.lnk

# Debug scripts for GMOD
lua/do.lua

# Don't sync VSCode configurations
.vscode

# Don't sync type definitions (generated by GmodWikiScraper)
lua/types

# Don't sync compiled shaders created for auto-reload workaround
shaders/fxc/splashsweps/[0-9]*_*.vcs

# Don't sync AI generated temporary files
.gemini
.opencode/work

# Don't sync custom Neovim config itself
.nvim.lua
