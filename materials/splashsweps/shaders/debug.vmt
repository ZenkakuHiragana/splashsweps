"Screenspace_General_8Tex"
{
    // Debug shader for Screenspace_General_8Tex investigation.
    // $c0_x < 0 : sampler preview
    // $c3_w > 0 : show vertex payload instead of pixel constants
    "$pixshader"           "splashsweps/debug_ps30"
    "$vertexshader"        "splashsweps/debug_vs30"
    "$linearread_basetexture" "1"
    "$linearread_texture1" "1"
    "$linearread_texture2" "1"
    "$linearread_texture3" "1"

    "$basetexture"  "hunter/myplastic"
    "$texture1"     "hunter/myplastic_normal"
    "$texture2"     "splashsweps/debug/numbers"
    "$texture3"     "splashsweps/debug/numbers"
    "$texture4"     "white"
    "$texture5"     "white"
    "$texture6"     "white"
    "$texture7"     "white"

    "$cull"         "1"
    "$depthtest"    "0"
    "$vertexalpha"  "1"
    "$vertexcolor"  "1"
    "$vertexnormal" "1"
    "$tcsize0"      "4"
    "$tcsize1"      "4"
    "$tcsize2"      "4"
    "$tcsize3"      "4"
    "$tcsize4"      "4"
    "$tcsize5"      "4"
    "$tcsize6"      "4"
    "$tcsize7"      "4"
    "$viewprojmat"    "[0.25 0 0 0.0625   0 0.25 0.0 0.125   0 0 0.25 0.25   0.25 0.25 0.25 0.375]"
    "$invviewprojmat" "[0.25 0 0 0.0625   0 0.25 0.0 0.125   0 0 0.25 0.25   0.25 0.25 0.25 0.375]"
    "$c0_x" "0"
    "$c0_y" "0"
    "$c0_z" "0"
    "$c0_w" "0"
    "$c1_x" "0"
    "$c1_y" "0"
    "$c1_z" "0"
    "$c1_w" "0"
    "$c2_x" "0"
    "$c2_y" "0"
    "$c2_z" "0"
    "$c2_w" "0"
    "$c3_x" "0"
    "$c3_y" "0"
    "$c3_z" "0"
    "$c3_w" "1"
}
